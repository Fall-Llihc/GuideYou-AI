# Copy to backend/.env and fill in real values for local development.
# In production (Railway), set these as environment variables under the
# service's "Variables" tab in the Railway dashboard.

# Required: Gemini API key for LLM narrative generation.
# Get one at https://aistudio.google.com/app/apikey (free tier available).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: legacy Groq key. The app reads GEMINI_API_KEY first and falls
# back to GROQ_API_KEY if set, which lets old Railway deployments keep
# working until you rename the variable.
# GROQ_API_KEY=gsk_your_groq_api_key_here

# CORS — comma-separated list of allowed frontend origins.
# Local dev:  http://localhost:3000
# Production: https://bandung-travel.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Optional overrides
GEMINI_MODEL=gemini-1.5-flash
LOG_LEVEL=INFO
