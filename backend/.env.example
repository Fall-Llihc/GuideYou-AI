# Copy to backend/.env and fill in real values for local development.
# In production (Railway), set these as environment variables under the
# service's "Variables" tab in the Railway dashboard.

# Required: Groq API key for LLM narrative generation.
# Get one at https://console.groq.com (free tier available).
GROQ_API_KEY=gsk_your_groq_api_key_here

# CORS — comma-separated list of allowed frontend origins.
# Local dev:  http://localhost:3000
# Production: https://bandung-travel.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Optional overrides
GROQ_MODEL=llama-3.1-8b-instant
LOG_LEVEL=INFO
