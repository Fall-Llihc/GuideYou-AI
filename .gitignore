# ─── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/
env/

# ─── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Environment files ───────────────────────────────────
# Never commit secrets — keep .env.example as template
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local

# ─── OS / IDE ────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Frontend (CRA) ──────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Notebook training artifacts (regenerable) ──────────
# We commit /models/*.pkl (deployed alongside backend) but
# ignore heavy intermediate training outputs anywhere else.
notebooks/data/raw/*.csv
notebooks/data/processed/*.npy
notebooks/data/processed/*.png

# ─── Allow these to be tracked ───────────────────────────
!models/.gitkeep
!backend/data/.gitkeep
.artifact-backup/
